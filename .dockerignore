# ── Build output ──────────────────────────────────────────────────────────────
target/
*.jar
*.war

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Docker files (don't send back into the build context) ────────────────────
Dockerfile
